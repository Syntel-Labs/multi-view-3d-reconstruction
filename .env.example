# Plantilla de variables de entorno. Copiar a .env y ajustar.
# Sincronizar con .env cada vez que se agregue/elimine variable.

# Identificacion del proyecto
PROJECT_NAME=multi-view-3d-reconstruction
PROJECT_PREFIX=mv3d

# Puertos expuestos al host
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Backend (FastAPI sobre uvicorn dentro del contenedor mv3d-hartley)
BACKEND_HOST=0.0.0.0
BACKEND_INTERNAL_PORT=8000
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
LOG_LEVEL=info

# Rutas dentro del contenedor backend
DATA_DIR=/app/data
OUTPUTS_DIR=/app/outputs
DATASETS_CONFIG=/app/data/datasets.yaml

# Frontend (Vite + Three.js dentro del contenedor mv3d-galileo)
FRONTEND_INTERNAL_PORT=5173
VITE_BACKEND_URL=http://localhost:8000

# Zona horaria
TZ=America/Guatemala
